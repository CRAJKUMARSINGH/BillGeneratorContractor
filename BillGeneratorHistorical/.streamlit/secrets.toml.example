# Streamlit Secrets Configuration Example
# Copy this file to .streamlit/secrets.toml and fill in your values
# DO NOT commit secrets.toml to version control!

# Application Configuration
[app]
name = "BillGenerator Historical"
version = "2.0.0"
mode = "production"

# Feature Flags (optional)
[features]
excel_upload = true
batch_processing = true
advanced_pdf = true
analytics = false

# Processing Settings (optional)
[processing]
max_file_size_mb = 200
enable_caching = true
auto_clean_cache = false

# API Keys (if needed in future)
# [api]
# openai_key = "your-api-key-here"
# google_cloud_key = "your-key-here"

# Database (if needed in future)
# [database]
# host = "your-db-host"
# port = 5432
# name = "billgen"
# user = "your-user"
# password = "your-password"
