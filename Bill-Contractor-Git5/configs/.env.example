# Bill Generator Backend — copy to backend/.env and fill in values

APP_NAME="Bill Generator"
VERSION="2.0.0"
DEBUG=false

# Paths (relative to backend/ working dir)
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
TEMPLATE_DIR=app/engine/renderer/templates

# Limits
MAX_UPLOAD_MB=20

# Redis (required for ARQ worker; leave default for local Docker)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
