# =============================================================================
# BillGeneratorContractor — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file to source control.
# =============================================================================

# ── Authentication ─────────────────────────────────────────────────────────────
# A strong random secret for JWT token signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Server will REFUSE to start if this is missing or matches insecure defaults.
SECRET_KEY=replace_with_a_64_char_random_hex_string

# ── Google / Gemini API ────────────────────────────────────────────────────────
# Primary Gemini Vision API key (used for OCR extraction).
# Obtain from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Optional backup key for API key rotation (used by APIKeyManager).
GEMINI_API_KEY_BACKUP=

# Path to Google Cloud service-account credentials JSON (for Cloud Vision API).
# Leave blank if using only Gemini.
GOOGLE_APPLICATION_CREDENTIALS=

# ── Redis / Job Queue ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example for production: https://your-app.example.com
# Defaults to localhost dev ports when unset.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite is fine for development; switch to PostgreSQL for production.
DATABASE_URL=sqlite:///./bill_generator.db

# ── Dev-only safety valve ──────────────────────────────────────────────────────
# Set to "1" ONLY in local development to allow a randomly-generated SECRET_KEY.
# Must NEVER be set in production.
ALLOW_INSECURE_SECRET=
