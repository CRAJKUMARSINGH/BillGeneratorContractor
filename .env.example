# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Dev-only escape hatch — set to 1 to allow a random key on startup (tokens invalidated on restart)
ALLOW_INSECURE_SECRET=0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Upload limits ─────────────────────────────────────────────────────────────
UPLOAD_LIMIT_MB=20

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4

# ── Template ──────────────────────────────────────────────────────────────────
DEFAULT_TEMPLATE_VERSION=v2
